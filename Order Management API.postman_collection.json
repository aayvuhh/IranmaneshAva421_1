  "item": [
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns customer object', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('_id');",
                  "  pm.expect(json.name).to.eql('Ali Iranmanesh');",
                  "  pm.expect(json.email).to.eql('ali@example.com');",
                  "  pm.collectionVariables.set('customerId', json._id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ali Iranmanesh\",\n  \"email\": \"ali@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/customers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "customers"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns order with Pending status', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('_id');",
                  "  pm.expect(json.status).to.eql('Pending');",
                  "  pm.collectionVariables.set('orderId', json._id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"items\": [\"Product 1\", \"Product 2\"],\n  \"totalAmount\": 99.99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            }
          },
          "response": []
        },
        {
